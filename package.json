{
  "name": "healthbridge",
  "version": "1.0.0",
  "private": true,
  "description": "Unified Health Information and Logistics Management Platform",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,css}\""
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "ts-node": "^10.9.2",
    "turbo": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "workspaces": [
    "apps/control-plane/*",
    "apps/tenant/*",
    "apps/landing",
    "packages/*"
  ],
  "packageManager": "npm@11.13.0"
}
