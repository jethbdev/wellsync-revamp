model PatientSession {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  token     String   @unique @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz
  ipAddress String?  @map("ip_address") @db.VarChar(100)
  userAgent String?  @map("user_agent") @db.VarChar(500)
  patientId String   @map("patient_id") @db.Uuid
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  facilityId String?  @map("facility_id") @db.Uuid
  orgId      String?  @map("org_id") @db.Uuid

  @@map("patient_sessions")
}

model PatientAccount {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId             String    @map("account_id") @db.VarChar(255)
  providerId            String    @map("provider_id") @db.VarChar(100)
  patientId             String    @map("patient_id") @db.Uuid
  patient               Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  accessToken           String?   @map("access_token") @db.Text
  refreshToken          String?   @map("refresh_token") @db.Text
  idToken               String?   @map("id_token") @db.Text
  expiresAt             DateTime? @map("expires_at") @db.Timestamptz
  password              String?   @map("password") @db.VarChar(300)
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  @@unique([providerId, accountId])
  @@map("patient_accounts")
}

model PatientVerification {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  identifier String    @db.VarChar(255)
  value      String    @db.VarChar(255)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime? @default(now()) @map("updated_at") @db.Timestamptz

  @@map("patient_verifications")
}

model QueueEntry {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  facilityId     String         @map("facility_id") @db.Uuid
  visitId        String?        @map("visit_id") @db.Uuid
  patientId      String         @map("patient_id") @db.Uuid
  ticketNumber   String         @map("ticket_number") @db.VarChar(20)
  status         String         @default("WAITING") @db.VarChar(20) // WAITING, CALLING, COMPLETED, SKIPPED
  calledRoom     String?        @map("called_room") @db.VarChar(50)
  doctorId       String?        @map("doctor_id") @db.Uuid
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime       @default(now()) @map("updated_at") @db.Timestamptz

  facility       Facility       @relation(fields: [facilityId], references: [id])
  patient        Patient        @relation(fields: [patientId], references: [id])
  doctor         User?          @relation(fields: [doctorId], references: [id])

  @@map("queue_entries")
}
